# ============================================================
# RotaLucro API - Variáveis de Ambiente
# ============================================================

# Ambiente
NODE_ENV=production
PORT=3000

# Supabase (opcional - para salvar dados)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon
SUPABASE_SERVICE_KEY=sua-chave-service

# Logging
LOG_LEVEL=info

# Workers
MAX_WORKERS=2

# Custos para cálculo de lucro
CUSTO_KM=0.80
PRECO_GASOLINA=6.30
